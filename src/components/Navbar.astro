---
import type { Lang } from '../i18n/ui';
import { useTranslations, APP_STORE_URL, getAltLangPath } from '../i18n/utils';

interface Props {
  lang: Lang;
  path: string;
}

const { lang, path } = Astro.props;
const t = useTranslations(lang);
const home = lang === 'de' ? '/de/' : '/';
const contactPath = lang === 'de' ? '/de/kontakt/' : '/contact/';

const altHref = getAltLangPath(lang, path);
---

<header class="sticky top-0 z-50 bg-white/85 backdrop-blur-xl border-b border-slate-200/60">
  <nav class="mx-auto max-w-7xl px-5 sm:px-8 h-16 flex items-center justify-between">
    <a href={home} class="flex items-center gap-2.5 font-semibold text-brand hover:opacity-80 transition-opacity">
      <img src="/logo.png" alt="SimpleTime" width="32" height="32" class="rounded-lg" />
      <span class="text-[17px] tracking-tight">SimpleTime</span>
    </a>

    <div class="hidden md:flex items-center gap-8 text-[15px] text-slate-700">
      <a href={`${home}#features`} class="hover:text-brand transition-colors">{t('nav.features')}</a>
      <a href={`${home}#screenshots`} class="hover:text-brand transition-colors">{t('nav.screenshots')}</a>
      <a href={contactPath} class="hover:text-brand transition-colors">{t('nav.contact')}</a>
    </div>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={altHref}
        class="text-sm text-slate-600 hover:text-brand transition-colors px-2 py-1 rounded-md"
        aria-label={`Switch to ${t('lang.switch')}`}
      >
        {lang === 'de' ? 'EN' : 'DE'}
      </a>
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center gap-1.5 bg-brand hover:bg-brand-dark text-white text-[14px] font-medium px-4 py-2 rounded-full transition-colors"
      >
        {t('nav.appstore')}
        <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 3h6v6" />
          <path d="M3 9l6-6" />
        </svg>
      </a>
    </div>
  </nav>
</header>
