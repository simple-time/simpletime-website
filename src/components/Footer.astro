---
import type { Lang } from '../i18n/ui';
import { useTranslations, APP_STORE_URL, CONTACT_EMAIL } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const prefix = lang === 'de' ? '/de' : '';
const links = {
  contact: `${prefix}/contact/`,
  imprint: `${prefix}/imprint/`,
  privacy: `${prefix}/privacy/`,
};
---

<footer class="bg-slate-950 text-slate-300 mt-24">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <div class="col-span-2">
        <div class="flex items-center gap-2.5">
          <img src="/logo.png" alt="" width="36" height="36" class="rounded-lg" />
          <span class="text-white font-semibold text-lg tracking-tight">SimpleTime</span>
        </div>
        <p class="mt-3 text-sm text-slate-400 max-w-sm">{t('footer.tagline')}</p>
      </div>

      <div>
        <h4 class="text-white font-medium text-sm mb-4">{t('footer.product')}</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href={APP_STORE_URL} target="_blank" rel="noopener" class="hover:text-white transition-colors">{t('footer.appstore')}</a></li>
          <li><a href={links.contact} class="hover:text-white transition-colors">{t('footer.contact')}</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-medium text-sm mb-4">{t('footer.legal')}</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href={links.imprint} class="hover:text-white transition-colors">{t('footer.imprint')}</a></li>
          <li><a href={links.privacy} class="hover:text-white transition-colors">{t('footer.privacy')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-xs text-slate-500">
      <p>{t('footer.copyright', { year })}</p>
      <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-slate-300 transition-colors">{CONTACT_EMAIL}</a>
    </div>
  </div>
</footer>
