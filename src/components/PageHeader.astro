---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="relative bg-brand text-white overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-accent/30 blur-[120px]"></div>
    <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-brand-light/40 blur-[120px]"></div>
  </div>
  <div class="relative mx-auto max-w-3xl px-5 sm:px-8 pt-20 pb-24 sm:pt-24 sm:pb-28 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight">{title}</h1>
    {subtitle && <p class="mt-5 text-lg text-blue-100/90 max-w-xl mx-auto">{subtitle}</p>}
  </div>
</section>
