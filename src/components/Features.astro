---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    key: 'instant',
    icon: `<path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/>`,
  },
  {
    key: 'structured',
    icon: `<rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="12" width="18" height="4" rx="1"/><rect x="3" y="20" width="10" height="0.01"/><path d="M7 16v4"/><path d="M7 8v4"/>`,
  },
  {
    key: 'timeline',
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  },
  {
    key: 'stats',
    icon: `<path d="M3 3v18h18"/><rect x="7" y="13" width="3" height="5" rx="0.5"/><rect x="12" y="9" width="3" height="9" rx="0.5"/><rect x="17" y="5" width="3" height="13" rx="0.5"/>`,
  },
  {
    key: 'icloud',
    icon: `<path d="M7 18a5 5 0 1 1 .9-9.92A7 7 0 0 1 21 11.5 4.5 4.5 0 0 1 17 18H7z"/>`,
  },
  {
    key: 'export',
    icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>`,
  },
  {
    key: 'private',
    icon: `<path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/><path d="M9 12l2 2 4-4"/>`,
  },
] as const;
---

<section id="features" class="relative py-24 sm:py-32 bg-white">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="max-w-3xl mx-auto text-center mb-16 sm:mb-20">
      <h2 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 leading-tight">
        {t('features.title')}
      </h2>
      <p class="mt-5 text-lg text-slate-600 leading-relaxed">
        {t('features.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {
        features.map((f) => (
          <div class="group relative p-7 sm:p-8 rounded-3xl bg-gradient-to-br from-slate-50 to-white border border-slate-200/70 hover:border-brand/30 hover:shadow-xl hover:shadow-brand/5 transition-all">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-brand/10 text-brand mb-5">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">
              {t(`features.${f.key}.title` as any)}
            </h3>
            <p class="text-[15px] text-slate-600 leading-relaxed">
              {t(`features.${f.key}.body` as any)}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
