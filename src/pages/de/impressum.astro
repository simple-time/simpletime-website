---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { useTranslations, CONTACT_EMAIL } from '../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);
---

<Layout lang={lang} path="/de/impressum/" title={`${t('imprint.title')} · SimpleTime`}>
  <PageHeader title={t('imprint.title')} />

  <article class="mx-auto max-w-3xl px-5 sm:px-8 py-16 sm:py-20">
    <h2 class="text-xl font-semibold text-slate-900 mt-0">{t('imprint.according')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">
      Luca Efinger<br />
      Friedrich-Ebert-Ring 16<br />
      97072 Würzburg<br />
      Deutschland
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('imprint.contact')}</h2>
    <p class="mt-3 text-slate-700">
      E-Mail: <a href={`mailto:${CONTACT_EMAIL}`} class="text-brand hover:underline">{CONTACT_EMAIL}</a>
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('imprint.responsible')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">
      Luca Efinger<br />
      Friedrich-Ebert-Ring 16<br />
      97072 Würzburg<br />
      Deutschland
    </p>

    <h2 class="text-2xl font-bold text-slate-900 mt-14">{t('imprint.disclaimer.title')}</h2>

    <h3 class="text-lg font-semibold text-slate-900 mt-8">{t('imprint.disclaimer.liability.title')}</h3>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('imprint.disclaimer.liability.body')}</p>

    <h3 class="text-lg font-semibold text-slate-900 mt-8">{t('imprint.disclaimer.links.title')}</h3>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('imprint.disclaimer.links.body')}</p>

    <h3 class="text-lg font-semibold text-slate-900 mt-8">{t('imprint.disclaimer.copyright.title')}</h3>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('imprint.disclaimer.copyright.body')}</p>
  </article>
</Layout>
