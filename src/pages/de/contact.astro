---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { useTranslations, CONTACT_EMAIL } from '../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);
---

<Layout lang={lang} path="/de/contact/" title={`${t('contact.title')} · SimpleTime`}>
  <PageHeader title={t('contact.title')} subtitle={t('contact.subtitle')} />

  <section class="mx-auto max-w-2xl px-5 sm:px-8 py-20">
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-50 to-white p-8 sm:p-10">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-brand">{t('contact.email.label')}</h2>
      <p class="mt-3 text-slate-700 leading-relaxed">{t('contact.email.body')}</p>

      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="mt-6 inline-flex items-center gap-2 text-xl sm:text-2xl font-semibold text-brand hover:text-brand-dark transition-colors break-all"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <polyline points="3 7 12 13 21 7" />
        </svg>
        {CONTACT_EMAIL}
      </a>

      <p class="mt-8 text-sm text-slate-500 leading-relaxed">{t('contact.response')}</p>
    </div>
  </section>
</Layout>
