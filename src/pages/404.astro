---
import Layout from '../layouts/Layout.astro';
---

<Layout lang="en" path="/404/" title="404 · Page not found · SimpleTime">
  <section class="relative overflow-hidden">
    <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-accent/20 blur-[120px]"></div>
      <div class="absolute -bottom-32 -right-32 w-[500px] h-[500px] rounded-full bg-brand-light/30 blur-[120px]"></div>
    </div>

    <div class="relative mx-auto max-w-3xl px-5 sm:px-8 py-28 sm:py-36 text-center">
      <p class="text-[120px] sm:text-[160px] font-bold tracking-tight leading-none text-brand">404</p>

      <h1 class="mt-6 text-3xl sm:text-4xl font-bold tracking-tight text-slate-900">
        Page not found
      </h1>
      <p class="mt-2 text-xl sm:text-2xl font-medium text-slate-500">
        Seite nicht gefunden
      </p>

      <p class="mt-8 text-slate-700 leading-relaxed max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <p class="mt-2 text-slate-500 leading-relaxed max-w-md mx-auto">
        Die Seite, die du suchst, existiert nicht oder wurde verschoben.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          id="home-link"
          href="/"
          class="inline-flex items-center gap-2 bg-brand hover:bg-brand-dark text-white font-medium px-6 py-3 rounded-full transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" />
            <path d="m12 19-7-7 7-7" />
          </svg>
          <span id="home-link-label">Back to home</span>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      if (window.location.pathname.startsWith('/de/')) {
        const link = document.getElementById('home-link');
        const label = document.getElementById('home-link-label');
        if (link) link.setAttribute('href', '/de/');
        if (label) label.textContent = 'Zurück zur Startseite';
      }
    })();
  </script>
</Layout>
