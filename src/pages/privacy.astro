---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { useTranslations, CONTACT_EMAIL } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const lastUpdated = '2026-04-17';
const formatted = new Date(lastUpdated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout lang={lang} path="/privacy/" title={`${t('privacy.title')} · SimpleTime`}>
  <PageHeader title={t('privacy.title')} />

  <article class="mx-auto max-w-3xl px-5 sm:px-8 py-16 sm:py-20">
    <p class="text-sm text-slate-500">{t('privacy.lastUpdated')}: {formatted}</p>

    <h2 class="text-xl font-semibold text-slate-900 mt-8">{t('privacy.intro.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.intro.body')}</p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('privacy.app.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.app.body')}</p>

    <h3 class="text-lg font-semibold text-slate-900 mt-6">{t('privacy.app.nocollect.title')}</h3>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.app.nocollect.body')}</p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('privacy.website.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.website.body')}</p>

    <h3 class="text-lg font-semibold text-slate-900 mt-6">{t('privacy.website.hosting.title')}</h3>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.website.hosting.body')}</p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('privacy.rights.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.rights.body')}</p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('privacy.contact.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.contact.body')}</p>
    <p class="mt-3 text-slate-700 leading-relaxed">
      Luca Efinger<br />
      Friedrich-Ebert-Ring 16<br />
      97072 Würzburg<br />
      Deutschland<br />
      <a href={`mailto:${CONTACT_EMAIL}`} class="text-brand hover:underline">{CONTACT_EMAIL}</a>
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10">{t('privacy.changes.title')}</h2>
    <p class="mt-3 text-slate-700 leading-relaxed">{t('privacy.changes.body')}</p>
  </article>
</Layout>
